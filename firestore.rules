rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is a member of a specific workspace
    // This assumes a workspaceUsers collection where doc ID is {workspaceId}_{userId}
    function isWorkspaceMember(workspaceId) {
      return exists(/databases/$(database)/documents/workspaceUsers/$(workspaceId + '_' + request.auth.uid));
    }
    
    // Check if the user is an admin or owner of a specific workspace
    function isWorkspaceAdmin(workspaceId) {
      let membership = get(/databases/$(database)/documents/workspaceUsers/$(workspaceId + '_' + request.auth.uid));
      return isWorkspaceMember(workspaceId) && membership.data.role in ['admin', 'owner'];
    }

    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      // Only owner can update workspace settings, and cannot change owner
      allow update: if isWorkspaceAdmin(workspaceId) && request.resource.data.ownerUid == resource.data.ownerUid;
      // Workspace creation is handled by a backend function to ensure consistency
      allow create: if request.resource.data.ownerUid == request.auth.uid;
      // Deletion might be restricted to owners only
      allow delete: if get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUid == request.auth.uid;
    }

    match /workspaceUsers/{membershipId} {
      // Users can see their own membership, admins can see all memberships in a workspace
      allow get: if isWorkspaceMember(resource.data.workspaceId);
      // List memberships for a workspace you are a member of
      allow list: if request.query.workspaceId != null && isWorkspaceMember(request.query.workspaceId);
      // Admins can add/remove users
      allow create, delete: if isWorkspaceAdmin(request.resource.data.workspaceId);
       // Admins can update roles
      allow update: if isWorkspaceAdmin(resource.data.workspaceId);
    }
    
    match /contactCategories/{categoryId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow write: if isWorkspaceMember(request.resource.data.workspaceId);
    }

    match /posts/{postId} {
      // Members can read posts in their workspace
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      // Members can list posts for a workspace they are in
      allow list: if request.query.workspaceId != null && isWorkspaceMember(request.query.workspaceId);
      // Members can create/update posts in their workspace
      allow create, update: if isWorkspaceMember(request.resource.data.workspaceId);
      // Members can delete posts in their workspace
      allow delete: if isWorkspaceMember(resource.data.workspaceId);
    }

    match /scheduledPosts/{postId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow delete: if false;
    }

    match /draftPosts/{draftId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }

    match /socialAccounts/{accountId} {
      // Members can view social accounts linked to their workspace
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow list: if request.query.workspaceId != null && isWorkspaceMember(request.query.workspaceId);
      // Only admins can add/edit/remove social accounts
      allow write: if isWorkspaceAdmin(request.resource.data.workspaceId);
    }

    match /notifications/{notificationId} {
      allow create: if false;
      allow get: if isWorkspaceMember(resource.data.workspaceId);
      allow list: if request.query.workspaceId != null && isWorkspaceMember(request.query.workspaceId);

      allow update: if isWorkspaceMember(resource.data.workspaceId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy is list
        && request.resource.data.readBy.size() >= resource.data.readBy.size()
        && request.resource.data.readBy.hasAll(resource.data.readBy)
        && request.resource.data.readBy.size() <= resource.data.readBy.size() + 1
        && (
          request.resource.data.readBy.size() == resource.data.readBy.size()
          || (
            request.resource.data.readBy.size() == resource.data.readBy.size() + 1
            && !resource.data.readBy.hasAny([request.auth.uid])
            && request.resource.data.readBy.hasAll(
              resource.data.readBy + [request.auth.uid]
            )
          )
        );

      allow delete: if false;
    }

    match /accountMetrics/{metricId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /competitorMetrics/{metricId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /competitors/{competitorId}/metricsSnapshots/{snapshotId} {
        allow read: if isWorkspaceMember(get(/databases/$(database)/documents/competitors/$(competitorId)).data.workspaceId);
        allow write: if false;
    }
  }
}
